    <title>سایت شخصی من</title>
    <meta name="description" content="اولین سایت من که با گوشی ساختم">

    <style>
        body {
            margin: 0;
            font-family: Arial;
            background: linear-gradient(135deg, #00c6ff, #0072ff);
            color: white;
            text-align: center;
        }

        .container {
            margin-top: 120px;
            padding: 20px;
        }

        h1 {
