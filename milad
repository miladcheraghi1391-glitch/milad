            border-radius: 10px;
            cursor: pointer;
            font-size: 16px;
        }
    </style>
</head>

<body>

<div class="container">
    <div class="box">
        <h1>🚀 سلام! من Milad هستم</h1>
        <p>این اولین سایت منه که خودم ساختم</p>
        <button onclick="alert('خوش اومدی 👋')">کلیک کن</button>
    </div>
